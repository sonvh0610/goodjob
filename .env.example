NODE_ENV=development
HOST=0.0.0.0
PORT=3000

DATABASE_URL=postgres://app:app@localhost:54322/goodjob
REDIS_URL=redis://localhost:6379

APP_BASE_URL=http://localhost:4200
API_BASE_URL=http://localhost:3000

SESSION_COOKIE_NAME=goodjob_session
SESSION_TTL_HOURS=168
JWT_SECRET=change-me-with-at-least-32-characters

S3_ENDPOINT=http://localhost:9000
S3_REGION=ap-southeast-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=goodjob-media

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/oauth/google/callback

SLACK_OAUTH_CLIENT_ID=
SLACK_OAUTH_CLIENT_SECRET=
SLACK_OAUTH_REDIRECT_URI=http://localhost:3000/auth/oauth/slack/callback

RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# Leave empty in local dev to use same-origin via Vite proxy.
VITE_API_BASE_URL=
# Optional websocket-capable origin for realtime when the HTTP API is behind a proxy
# that does not forward websocket upgrades (for example some Vercel rewrite setups).
VITE_WS_BASE_URL=
# Optional override for Vite dev proxy target.
VITE_DEV_API_PROXY_TARGET=http://localhost:3000
